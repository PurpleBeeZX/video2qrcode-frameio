# =============================================================================
# Frame.io V4 QR Code Automation System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials.
#   cp .env.example .env
#
# The .env file is gitignored and will never be committed to GitHub.
# =============================================================================

# --- Frame.io / Adobe IMS Credentials (REQUIRED) ---
# Get these from the Adobe Developer Console:
#   https://developer.adobe.com/console/
FRAMEIO_CLIENT_ID=your_client_id_here
FRAMEIO_CLIENT_SECRET=your_client_secret_here
FRAMEIO_FOLDER_ID=your_folder_id_here

# --- Server Settings (Optional — defaults shown) ---
FRAMEIO_SERVER_HOST=0.0.0.0
FRAMEIO_SERVER_PORT=8000

# NOTE: SSL certificates are now stored directly in config.json.
# Do NOT set FRAMEIO_SSL_CERTFILE or FRAMEIO_SSL_KEYFILE here.

# --- Folder Paths (Optional — defaults shown) ---
FRAMEIO_WATCH_FOLDER=data/watch_folder
FRAMEIO_PROCESSED_FOLDER=data/processed_folder
FRAMEIO_FAILED_FOLDER=data/failed_folder
FRAMEIO_QR_CODES_FOLDER=data/qr_codes

# --- OAuth Settings (Optional — defaults shown) ---
FRAMEIO_REDIRECT_URI=https://localhost:8000/callback
FRAMEIO_AUTH_URL=https://ims-na1.adobelogin.com/ims/authorize/v2
FRAMEIO_TOKEN_URL=https://ims-na1.adobelogin.com/ims/token/v3
FRAMEIO_OAUTH_SCOPE=offline_access,openid,email,profile,additional_info.roles